#### Information ####
/run/verbose 0
/control/verbose 0

# Cuts
/run/setCut 1 nm
/cuts/setLowEdge 100 eV
/process/em/lowestElectronEnergy 100 eV

# ion parameters 
/process/em/lowestMuHadEnergy 20 eV
/process/em/lowestElectronEnergy 20 eV
/process/eLoss/StepFunctionIons 0.1 10 nm

# Activate some process 
/process/em/fluo true
/process/em/auger true
/process/em/augerCascade true
/process/em/deexcitationIgnoreCut true


#### Choosing physics ####
/physics/setPhysics G4EmDNAPhysics_option2
#/physics/setPhysics G4EmStandardPhysics_option4
#/physics/setPhysics G4EmLivermorePhysics




#### Run ####
/run/initialize

#### Simplifications and parameters for modeling ####
/process/inactivate e-_G4DNAElastic
/process/inactivate e-_G4DNAVibExcitation
/process/inactivate e-_G4DNAAttachment
/process/inactivate e-_G4DNAElectronSolvation
/process/inactivate alpha_G4DNAExcitation
/process/inactivate alpha_G4DNAElastic
/process/inactivate alpha_G4DNAChargeDecrease

/process/inactivate proton_G4DNAExcitation
/process/inactivate proton_G4DNAElastic
/process/inactivate proton_G4DNAChargeDecrease


#### Detector geometry ####
/detector/setCylinderLength 10 um
/detector/setCylinderRadius 5 mm
/run/geometryModified
/run/reinitializeGeometry

#### Choose your ion ####
#/gun/particle ion
#/gun/ion 6 12 6
#/gun/energy 24.022 MeV
#/run/beamOn 100

#/gun/particle ion
#/gun/ion 10 20 10
#/gun/energy 163.46 MeV
#/run/beamOn 100

#/gun/particle ion
#/gun/ion 10 20 10 
#/gun/energy 7615.06 MeV
